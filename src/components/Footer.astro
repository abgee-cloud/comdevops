---
// src/components/Footer.astro
// ABG DCD — IS&CT Unit

interface Props {
  startYear?: number;
}

const { startYear } = Astro.props;
const currentYear = new Date().getFullYear();
let yearDisplay = `${currentYear}`;
if (startYear && startYear < currentYear) {
  yearDisplay = `${startYear}–${currentYear}`;
}
---
<footer role="contentinfo" class="site-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <div class="footer-badge">ABG</div>
      <div>
        <p class="footer-org">Department of Community Development</p>
        <p class="footer-sub">Autonomous Bougainville Government · IS&amp;CT Unit</p>
        <p class="footer-address">Buka, Autonomous Region of Bougainville, Papua New Guinea</p>
      </div>
    </div>

    <div class="footer-links">
      <p class="footer-links-title">Quick Links</p>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/about">About DCD</a></li>
        <li><a href="/programmes">Programmes</a></li>
        <li><a href="/publications">Publications</a></li>
        <li><a href="/news">News</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </div>

    <div class="footer-contact">
      <p class="footer-links-title">Contact IS&amp;CT</p>
      <p>📧 <a href="mailto:tmaioni.dcd@abg.gov.pg">tmaioni.dcd@abg.gov.pg</a></p>
      <p>🌐 <a href="https://abgee-cloud.github.io/comdevops" target="_blank" rel="noopener">abgee-cloud.github.io/comdevops</a></p>
    </div>
  </div>

  <div class="footer-bottom">
    <p>&copy; {yearDisplay} Autonomous Bougainville Government — Department of Community Development. All rights reserved.</p>
    <p class="footer-disclaimer">Official ABG government website. Content is provided for public information purposes.</p>
  </div>
</footer>

<style>
.site-footer {
  background-color: var(--color-primary);
  border-top: 3px solid var(--color-accent);
  color: rgba(255,255,255,0.8);
  margin-top: var(--spacing-xxl);
}

.footer-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: var(--spacing-xxl) var(--spacing-md) var(--spacing-xl);
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  gap: var(--spacing-xl);
}

.footer-brand {
  display: flex;
  gap: var(--spacing-md);
  align-items: flex-start;
}

.footer-badge {
  background-color: var(--color-accent);
  color: var(--color-primary);
  font-weight: 900;
  font-size: 1.1rem;
  padding: 6px 10px;
  border-radius: var(--border-radius);
  letter-spacing: 1px;
  flex-shrink: 0;
  height: fit-content;
}

.footer-org {
  font-size: 1rem;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 0.2em;
}
.footer-sub {
  font-size: 0.82rem;
  color: rgba(255,255,255,0.65);
  margin-bottom: 0.2em;
}
.footer-address {
  font-size: 0.8rem;
  color: rgba(255,255,255,0.5);
}

.footer-links-title {
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--color-accent);
  font-weight: 700;
  margin-bottom: var(--spacing-sm);
}

.footer-links ul {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}
.footer-links a,
.footer-contact a {
  color: rgba(255,255,255,0.75);
  font-size: 0.88rem;
  text-decoration: none;
  transition: color 0.2s;
}
.footer-links a:hover,
.footer-contact a:hover {
  color: var(--color-accent);
  text-decoration: none;
}

.footer-contact p {
  font-size: 0.88rem;
  margin-bottom: 0.4rem;
}

.footer-bottom {
  border-top: 1px solid rgba(255,255,255,0.12);
  padding: var(--spacing-md);
  text-align: center;
  font-size: 0.78rem;
  color: rgba(255,255,255,0.45);
}
.footer-disclaimer {
  margin-top: 0.3em;
  font-size: 0.73rem;
}

@media (max-width: 768px) {
  .footer-inner {
    grid-template-columns: 1fr;
    gap: var(--spacing-xl);
  }
}
</style>
