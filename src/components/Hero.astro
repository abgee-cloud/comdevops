---
// src/components/Hero.astro
// ABG DCD — IS&CT Unit

interface Props {
  headline: string;
  subheadline?: string;
  ctaText: string;
  ctaHref: string;
  ctaSecondaryText?: string;
  ctaSecondaryHref?: string;
}

const { headline, subheadline, ctaText, ctaHref, ctaSecondaryText, ctaSecondaryHref } = Astro.props;
---
<section class="hero-section" aria-label="Welcome">
  <div class="hero-bg-pattern"></div>
  <div class="hero-content">
    <p class="hero-eyebrow">Autonomous Bougainville Government</p>
    <h1>{headline}</h1>
    {subheadline && <p class="subheadline">{subheadline}</p>}
    <div class="hero-actions">
      <a href={ctaHref} class="cta-primary">{ctaText}</a>
      {ctaSecondaryText && ctaSecondaryHref && (
        <a href={ctaSecondaryHref} class="cta-secondary">{ctaSecondaryText}</a>
      )}
    </div>
  </div>
</section>

<style>
.hero-section {
  position: relative;
  padding: var(--spacing-xxl) var(--spacing-md);
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: white;
  text-align: center;
  overflow: hidden;
}

/* Decorative pattern overlay */
.hero-bg-pattern {
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(circle at 20% 50%, rgba(201,168,76,0.08) 0%, transparent 50%),
    radial-gradient(circle at 80% 20%, rgba(255,255,255,0.04) 0%, transparent 40%);
  pointer-events: none;
}

/* Gold top accent bar */
.hero-section::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 4px;
  background: linear-gradient(90deg, var(--color-accent), transparent);
}

.hero-content {
  position: relative;
  max-width: 820px;
  margin: 0 auto;
}

.hero-eyebrow {
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--color-accent);
  font-weight: 600;
  margin-bottom: var(--spacing-sm);
}

.hero-content h1 {
  font-size: clamp(1.9rem, 5vw, 3rem);
  color: #ffffff;
  margin-bottom: var(--spacing-md);
  line-height: 1.15;
}

.subheadline {
  font-size: 1.15rem;
  color: rgba(255,255,255,0.78);
  margin-bottom: var(--spacing-xl);
  line-height: 1.6;
  max-width: 640px;
  margin-left: auto;
  margin-right: auto;
}

.hero-actions {
  display: flex;
  gap: var(--spacing-md);
  justify-content: center;
  flex-wrap: wrap;
}

.cta-primary {
  display: inline-block;
  padding: 14px var(--spacing-xl);
  background-color: var(--color-accent);
  color: var(--color-primary);
  text-decoration: none;
  border-radius: var(--border-radius);
  font-weight: 700;
  font-size: 0.95rem;
  transition: background-color 0.2s ease, transform 0.2s ease;
}
.cta-primary:hover {
  background-color: var(--color-accent-dark);
  transform: translateY(-2px);
  text-decoration: none;
  color: var(--color-primary);
}

.cta-secondary {
  display: inline-block;
  padding: 14px var(--spacing-xl);
  background-color: transparent;
  color: rgba(255,255,255,0.9);
  text-decoration: none;
  border-radius: var(--border-radius);
  font-weight: 600;
  font-size: 0.95rem;
  border: 1.5px solid rgba(255,255,255,0.35);
  transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
}
.cta-secondary:hover {
  border-color: var(--color-accent);
  color: var(--color-accent);
  background-color: rgba(201,168,76,0.08);
  text-decoration: none;
}

@media (max-width: 768px) {
  .hero-section { padding: var(--spacing-xl) var(--spacing-md); }
  .hero-actions { flex-direction: column; align-items: center; }
  .cta-primary, .cta-secondary { width: 100%; max-width: 300px; text-align: center; }
}
</style>
