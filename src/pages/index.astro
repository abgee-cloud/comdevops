---
// src/pages/index.astro
// ABG DCD — IS&CT Unit Homepage

import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import AboutSection from '../components/AboutSection.astro';
import CTASection from '../components/CTASection.astro';
import { featuresData } from '../data/featuresData';

const aboutContent = `
  <p>The <strong>Department of Community Development (DCD)</strong> is a principal line department of the Autonomous Bougainville Government responsible for coordinating community-centred social services across all 13 districts of Bougainville.</p>
  <p>Our mandate spans child protection, women and gender equity, youth development, community empowerment, and social welfare — delivered in partnership with communities, civil society, and development partners.</p>
  <p>The <strong>IS&amp;CT Unit</strong> drives digital transformation across DCD operations, building data systems and digital infrastructure to support evidence-based service delivery.</p>
`;
---
<Layout title="Home" description="Official web portal of the ABG Department of Community Development — serving communities across Bougainville.">

  <Hero
    headline="Building Stronger Communities Across Bougainville"
    subheadline="The Department of Community Development delivers integrated social services, policy leadership, and digital innovation to support the wellbeing of all Bougainvilleans."
    ctaText="Our Programmes"
    ctaHref="/programmes"
    ctaSecondaryText="About DCD"
    ctaSecondaryHref="/about"
  />

  <Features
    features={featuresData}
    sectionTitle="Our Programme Areas"
    sectionSubtitle="DCD delivers community-centred services across six core programme areas throughout Bougainville's urban and rural communities."
  />

  <section class="about-wrapper">
    <AboutSection
      headline="About the Department"
      content={aboutContent}
    />
  </section>

  <CTASection
    headline="Get in Touch with DCD"
    body="Have a query about our programmes, publications, or services? Contact the IS&CT Unit or your nearest district office."
    ctaText="Contact Us"
    ctaHref="/contact"
    ctaSecondaryText="Publications"
    ctaSecondaryHref="/publications"
  />

</Layout>

<style>
.about-wrapper {
  background-color: var(--color-surface);
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
}
</style>
