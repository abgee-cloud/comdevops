---
// src/pages/news.astro
import Layout from '../layouts/Layout.astro';
---
<Layout title="News">
  <div class="page-hero">
    <div class="container">
      <p class="page-eyebrow">ABG Department of Community Development</p>
      <h1>News</h1>
    </div>
  </div>
  <div class="page-body container">
    <p class="placeholder-notice">This page is under construction. Content will be added by the DCD IS&amp;CT Unit.</p>
  </div>
</Layout>

<style>
.page-hero {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: white;
  padding: var(--spacing-xxl) var(--spacing-md);
  border-bottom: 3px solid var(--color-accent);
}
.page-eyebrow {
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--color-accent);
  font-weight: 600;
  margin-bottom: var(--spacing-sm);
}
.page-hero h1 { color: #ffffff; font-size: clamp(1.6rem, 4vw, 2.4rem); }
.page-body { padding: var(--spacing-xxl) var(--spacing-md); }
.placeholder-notice {
  color: var(--color-text-muted);
  font-style: italic;
  border-left: 4px solid var(--color-accent);
  padding-left: var(--spacing-md);
}
</style>
